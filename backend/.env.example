# ─── OmniShop TMA Backend — Environment Variables ───
# Copy this file to .env and fill in your values.
# NEVER commit your .env file to version control.

# ── Database ──────────────────────────────────────────────
# Neon PostgreSQL connection string (postgresql+asyncpg for async SQLAlchemy)
DATABASE_URL=postgresql+asyncpg://user:password@host/dbname

# ── Telegram Bot ──────────────────────────────────────────
# Your Telegram Bot Token from @BotFather
TELEGRAM_BOT_TOKEN=123456789:ABCDEFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Secret token to validate incoming webhook requests from Telegram
# Generate a random string: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=your_webhook_secret_here

# Your personal Telegram user ID (you can find it from @userinfobot)
ADMIN_TELEGRAM_ID=123456789

# ── JWT Authentication ─────────────────────────────────────
# Secret key for signing JWTs — generate a strong random value
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=your_super_secret_jwt_key_here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Instagram Integration (Optional) ──────────────────────
# Leave empty if not using Instagram webhook
INSTAGRAM_VERIFY_TOKEN=
INSTAGRAM_APP_SECRET=
INSTAGRAM_ACCESS_TOKEN=

# ── App Config ─────────────────────────────────────────────
# URL of your deployed frontend (used for CORS)
FRONTEND_URL=http://localhost:3000

# Set to 'production' when deployed
ENVIRONMENT=development
